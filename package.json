{
  "name": "istpet-eventos",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "build": "npm run build --workspace frontend",
    "postinstall": "cd backend && npx prisma generate"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
